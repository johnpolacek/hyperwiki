{
  "projectName": "hyperwiki",
  "canonicalWiki": "html",
  "dev": {
    "host": "127.0.0.1",
    "port": 4177,
    "command": "pnpm dev",
    "previewUrl": "https://hyperwiki.localhost"
  },
  "worktrees": {
    "previewUrlPattern": "https://<branch-slug>.hyperwiki.localhost",
    "workflow": "parallel-dev-worktrees",
    "directory": "../hyperwiki.worktrees",
    "finishPolicy": "merge"
  },
  "agent": {
    "launchCommand": "codex --yolo"
  },
  "layout": {
    "panels": [
      {
        "name": "agent",
        "role": "agent",
        "command": "codex --yolo"
      },
      {
        "name": "dev",
        "role": "dev",
        "command": "pnpm dev"
      },
      {
        "name": "cli",
        "role": "shell",
        "command": null
      }
    ]
  },
  "runtimeState": ".hyperwiki/state",
  "sessions": ".hyperwiki/sessions"
}
