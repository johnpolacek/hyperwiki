{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hyperwiki",
  "version": "0.1.1",
  "identifier": "dev.hyperwiki.app",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "hyperwiki",
        "width": 1440,
        "height": 960,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
