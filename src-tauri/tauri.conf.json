{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hyperwiki",
  "version": "0.1.1",
  "identifier": "dev.hyperwiki.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:frontend",
    "beforeBuildCommand": "pnpm run build:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "hyperwiki",
        "width": 1720,
        "height": 1000,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
