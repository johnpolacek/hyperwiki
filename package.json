{
  "name": "hyperwiki",
  "version": "0.1.1",
  "description": "Localhost Tooling for docs-driven agentic development.",
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check:tauri": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:tauri": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:all": "pnpm run check && pnpm run check:tauri && pnpm run test:tauri && pnpm run smoke:api-adapter && pnpm run smoke:tauri-harness && pnpm run smoke:tauri-static-assets",
    "check": "node --check public/app-api.js && node --check public/app.js && node --check tests/api-adapter-smoke.mjs && node --check tests/tauri-harness-smoke.mjs && node --check tests/tauri-static-assets-smoke.mjs",
    "smoke:api-adapter": "node tests/api-adapter-smoke.mjs",
    "smoke:tauri-harness": "node tests/tauri-harness-smoke.mjs",
    "smoke:tauri-static-assets": "node tests/tauri-static-assets-smoke.mjs",
    "wt:doctor": "cargo run --manifest-path src-tauri/Cargo.toml -- wt doctor",
    "wt:create": "cargo run --manifest-path src-tauri/Cargo.toml -- wt create",
    "wt:list": "cargo run --manifest-path src-tauri/Cargo.toml -- wt list",
    "wt:resume": "cargo run --manifest-path src-tauri/Cargo.toml -- wt resume",
    "wt:open": "cargo run --manifest-path src-tauri/Cargo.toml -- wt open",
    "wt:finish": "cargo run --manifest-path src-tauri/Cargo.toml -- wt finish",
    "wt:prune": "cargo run --manifest-path src-tauri/Cargo.toml -- wt prune"
  },
  "dependencies": {},
  "devDependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@tauri-apps/cli": "^2.11.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "private": false
}
